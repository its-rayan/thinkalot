{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    // "baseUrl": ".", // Required for path aliases
    "paths": {
      "@db/*": ["./src/db/*"],
      "@routes/*": ["./src/routes/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["dist"]
}
